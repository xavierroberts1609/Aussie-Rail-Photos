generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  pendingName  String?
  email        String   @unique
  passwordHash String
  role         String   @default("USER")
  createdAt    DateTime @default(now())
  photos       Photo[]
}

model Photo {
  id          String    @id @default(cuid())
  title       String
  category    String
  imageUrl    String
  status      String    @default("PENDING")
  operator    String?
  trainLine   String?
  trainType   String?
  consist     String?
  state       String?
  suburb      String?
  station     String?
  locationDetail String?
  camera      String?
  dateTaken   DateTime?
  description String?
  createdAt   DateTime  @default(now())

  photographer   User   @relation(fields: [photographerId], references: [id])
  photographerId String
}
