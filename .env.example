# Copy this file to .env for local development and fill in real values.
# In production (Fly.io), these are set via `fly secrets set` / fly.toml [env]
# instead of committing a real .env file.

# Local dev: file:./dev.db
# Production (Fly volume): file:/data/prod.db
DATABASE_URL="file:./dev.db"

# Generate a strong random value for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="dev-only-secret-change-me-in-production"

# Must match the deployed URL exactly in production, e.g. https://your-app.fly.dev
NEXTAUTH_URL="http://localhost:3000"

# Whichever email registers with this address is auto-promoted to admin
ADMIN_EMAIL="AussieRailPhotos@gmail.com"
